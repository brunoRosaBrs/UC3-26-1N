--7) Mostre apenas os clientes que ainda não realizaram compras.

SELECT c.nome AS cliente, co.data_compra
FROM clientes c
LEFT JOIN compras co 
ON c.id = co.cliente_id
WHERE co.id IS NULL;



--8) Faça uma consulta utilizando RIGHT JOIN retornando todas as compras e seus respectivos clientes.

SELECT c.nome AS cliente,
       p.nome AS produto,
       co.data_compra
FROM compras co
RIGHT JOIN clientes c
ON c.id = co.cliente_id
RIGHT JOIN produtos p
ON p.id = co.produto_id;


--9) Liste cliente, produto, quantidade e preço utilizando INNER JOIN.

SELECT c.nome AS cliente, p.nome AS produto, co.quantidade, p.preco
FROM clientes c
INNER JOIN compras co 
ON c.id = co.cliente_id
INNER JOIN produtos p 
ON p.id = co.produto_id;



--10) Liste todas as compras realizadas em fevereiro de 2025.

SELECT
    c.nome AS cliente,
    p.nome AS produto,
    co.data_compra
FROM clientes c
INNER JOIN compras co
ON c.id = co.cliente_id
INNER JOIN produtos p
ON p.id = co.produto_id
WHERE EXTRACT(MONTH FROM co.data_compra) = 2
AND EXTRACT(YEAR FROM co.data_compra) = 2025;



--DESAFIO

SELECT 
    c.nome AS cliente,
    c.cidade,
    p.nome AS produto,
    p.categoria,
    co.quantidade,
    p.preco AS preco_unitario,
    (co.quantidade * p.preco) AS valor_total,
    co.data_compra
FROM clientes c
INNER JOIN compras co 
ON c.id = co.cliente_id
INNER JOIN produtos p 
ON p.id = co.produto_id
ORDER BY valor_total DESC, c.nome ASC;








